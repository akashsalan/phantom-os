<Window x:Class="PhantomOS.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phantom-OS Settings" Height="720" Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1E" Foreground="White"
        Topmost="True" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#8888BB"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Background" Value="#1A1A30"/>
            <Setter Property="Foreground" Value="#D8D8F0"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#AAAAFF"/>
        </Style>
        
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="12,6" BorderThickness="0,0,0,2" Margin="0,0,8,0" Background="Transparent" BorderBrush="Transparent">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF8844" Offset="0"/>
                                            <GradientStop Color="#FF44AA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#FFD0AA"/>
                                <Setter TargetName="ContentSite" Property="TextElement.FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#666688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with gradient text effect -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="⚙  PHANTOM-OS SETTINGS" FontWeight="Bold" FontSize="16"
                       Foreground="#7070BB" FontFamily="Segoe UI"/>
            <TextBlock Text="Configure your stealth AI assistant" FontSize="10.5"
                       Foreground="#3A3A55" FontFamily="Segoe UI" Margin="0,3,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="0,0,0,16">
            <TabItem Header="API CONNECTION">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="API PROVIDER" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="ProviderCombo" Padding="10,8" Margin="0,0,0,16"
                                  Background="#1A1A30" Foreground="Black" BorderBrush="#2A2A45"
                                  FontSize="13" SelectionChanged="ProviderCombo_SelectionChanged">
                            <ComboBoxItem Content="OpenAI" Tag="openai"/>
                            <ComboBoxItem Content="Google Gemini" Tag="google"/>
                            <ComboBoxItem Content="Anthropic Claude" Tag="anthropic"/>
                            <ComboBoxItem Content="HuggingFace" Tag="huggingface"/>
                            <ComboBoxItem Content="Custom (OpenAI Compatible)" Tag="custom"/>
                        </ComboBox>

                        <TextBlock Text="API BASE URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="UrlBox" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="API KEY" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="ApiKeyBox" Padding="12,10" Margin="0,0,0,16"
                                     Background="#1A1A30" Foreground="#D8D8F0" BorderBrush="#2A2A45"
                                     FontFamily="Cascadia Code, Consolas" FontSize="13"
                                     BorderThickness="1"/>

                        <TextBlock Text="MODEL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="ModelBox" Style="{StaticResource InputBox}"/>

                        <TextBlock Text="SESSION PRESET" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="PresetCombo" Padding="10,8" Margin="0,0,0,16"
                                  Background="#1A1A30" Foreground="Black" BorderBrush="#2A2A45"
                                  FontSize="13">
                            <ComboBoxItem Content="Interview Companion" Tag="interview"/>
                            <ComboBoxItem Content="Code &amp; Tutorial" Tag="code"/>
                            <ComboBoxItem Content="Meeting Assistant" Tag="meeting"/>
                        </ComboBox>

                        <TextBlock Text="OCR ENGINE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="OcrEngineCombo" Padding="10,8" Margin="0,0,0,16"
                                  Background="#1A1A30" Foreground="Black" BorderBrush="#2A2A45"
                                  FontSize="13">
                            <ComboBoxItem Content="Tesseract (High Accuracy)" Tag="tesseract"/>
                            <ComboBoxItem Content="Windows OCR (Fast)" Tag="windows"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="SHORTCUTS">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="Set global keyboard shortcuts (Requires app restart to bind)" 
                                   Foreground="#555577" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"
                                   FontFamily="Segoe UI"/>

                        <TextBlock Text="INSTANT CAPTURE &amp; FIRE" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyInstantCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="APPEND BATCH (Silent)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyAppendCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="SEARCH BATCH" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeySearchCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="TOGGLE AUDIO RECORD" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyAudioCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="CLEAR CONTEXT" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyClearCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="TOGGLE UI VISIBILITY" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyHideCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />

                        <TextBlock Text="RESET OVERLAY" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="KeyResetCombo" Padding="4,6" Margin="0,0,0,12" Background="#1A1A30" Foreground="Black" FontSize="13" BorderBrush="#2A2A45" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2">
            <Button Content="SAVE &amp; APPLY" Padding="14,11" Margin="0,12,0,0"
                    FontWeight="Bold" FontSize="13" Cursor="Hand"
                    Foreground="White" BorderThickness="0"
                    Click="Save_Click">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3366DD" Offset="0"/>
                        <GradientStop Color="#5544CC" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="QUIT PHANTOM-OS" Padding="14,10" Margin="0,10,0,0"
                    Background="#1A0808" Foreground="#FF8888" BorderThickness="1"
                    BorderBrush="#331111"
                    FontWeight="Bold" FontSize="12" Cursor="Hand"
                    Click="Quit_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="Settings are encrypted and stored locally."
                       Foreground="#333355" FontSize="10" Margin="0,14,0,0"
                       HorizontalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>
    </Grid>
</Window>
